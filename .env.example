# =========================================================================
#  AtomEve — environment variables
#  Copy this file to ".env" and fill in the real values from the
#  Discord Developer Portal. NEVER commit the real ".env" file.
# =========================================================================

# Application ID  (Developer Portal -> General Information -> Application ID)
DISCORD_APP_ID=your_application_id_here

# Public Key  (Developer Portal -> General Information -> Public Key)
# Used to cryptographically verify that requests really come from Discord.
DISCORD_PUBLIC_KEY=your_public_key_here

# Bot Token  (Developer Portal -> Bot -> Reset Token -> Copy)
# Secret. Used only for REST calls (e.g. /serverinfo) and command registration.
DISCORD_BOT_TOKEN=your_bot_token_here

# (Optional) Guild ID for instant command registration during development.
# Leave empty to register commands globally (can take up to ~1 hour to appear).
DISCORD_GUILD_ID=
